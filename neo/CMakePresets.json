{
  "version": 3,
  "configurePresets": [
    {
      "name": "macos-setup",
      "hidden": true,
      "cacheVariables": {
        "OPENAL_INCLUDE_DIR": "/opt/homebrew/opt/openal-soft/include",
        "OPENAL_LIBRARY": "/opt/homebrew/opt/openal-soft/lib/libopenal.dylib"
      }
    },
    {
      "name": "linux-setup",
      "hidden": true,
      "cacheVariables": {}
    },
    {
      "name": "debug",
      "inherits": "macos-setup",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/../build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "inherits": "macos-setup",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/../build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "gles3-debug",
      "inherits": "macos-setup",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/../build/gles3",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "GLES3": "ON"
      }
    },
    {
      "name": "gles3-release",
      "inherits": "macos-setup",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/../build/gles3-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "GLES3": "ON"
      }
    },
    {
      "name": "linux-debug",
      "inherits": "linux-setup",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/../build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "linux-release",
      "inherits": "linux-setup",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/../build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "gles3-debug",
      "configurePreset": "gles3-debug"
    },
    {
      "name": "gles3-release",
      "configurePreset": "gles3-release"
    },
    {
      "name": "linux-debug",
      "configurePreset": "linux-debug"
    },
    {
      "name": "linux-release",
      "configurePreset": "linux-release"
    }
  ],
  "testPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "configurePreset": "release"
    }
  ]
}
